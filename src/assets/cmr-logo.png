<!-- search -->
<script>
  $(document).ready(function () {
    $('.toggle_link_heading').on('click', function () {
      var $trigger = $(this).find('p');
      var target = $trigger.attr('href');

      // If already open, close it
      if ($(target).hasClass('show')) {
        $(target).removeClass('show').slideUp();
        $trigger.removeClass('active');
      } else {
        // Close others
        $('#accordion .collapse').removeClass('show').slideUp();
        $('#accordion .toggle_link_heading p').removeClass('active');

        // Open this one
        $(target).addClass('show').slideDown();
        $trigger.addClass('active');
      }

      return false; // Prevent default anchor behavior
    });
  });
</script>

<script>
  
    // search box

    document.addEventListener("DOMContentLoaded", function () {
      const searchInput = document.querySelector(".search-input");
      const searchResults = document.createElement("div");
      searchResults.classList.add("search-results");
      document.body.appendChild(searchResults);
  
      searchInput.addEventListener("input", function () {
          let query = searchInput.value.trim().toLowerCase();
          if (query.length > 2) {
              fetchSearchResults(query);
          } else {
              searchResults.innerHTML = "";
              searchResults.style.display = "none";
          }
      });
  
      async function fetchSearchResults(query) {
          // Example: Fetch results from WordPress or API
          let response = await fetch(`/wp-json/wp/v2/posts?search=${query}`);
          let results = await response.json();
  
          displayResults(results);
      }
  
      function displayResults(results) {
          searchResults.innerHTML = "";
          if (results.length === 0) {
              searchResults.innerHTML = "<p>No results found</p>";
          } else {
              results.forEach(result => {
                  let item = document.createElement("a");
                  item.href = result.link;
                  item.textContent = result.title.rendered;
                  item.classList.add("search-result-item");
                  searchResults.appendChild(item);
              });
          }
          searchResults.style.display = "block";
      }
  });
</script>



<script type="text/javascript">
  // header sec scroll time add class name

$(window).scroll(function() {
      var scroll = $(window).scrollTop();
      if (scroll >= 50) {
          $("#header").addClass("sticky_header");
      } else {
          $("#header").removeClass("sticky_header");
      }

      if (scroll >= 50) {
          $(".common_mbl_btn").addClass("sticky_mbl_btn");
      } else {
          $(".common_mbl_btn").removeClass("sticky_mbl_btn");
      }
  });

