    // smoothly scroll
	$('a[href^="#"]').on('click', function (e) {
		var target = this.hash;
		if (!target) return;

		var $target = $(target);
		if (!$target.length) return; // FIX

		e.preventDefault();

		$('html, body').stop().animate(
			{
				scrollTop: $target.offset().top - 200
			},
			500,
			'swing',
			function () {
				window.location.hash = target;
			}
		);
	});
	 
	
	
	
	
    // school detail page scroll js end
</script>



