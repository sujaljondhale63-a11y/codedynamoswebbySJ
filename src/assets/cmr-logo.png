.dot-border {
	position: relative;
	border-bottom: 1px solid #D9D9D9!important;
}
.dot-border::before {
	content: "";
	position: absolute;
	bottom: -2.5px;
	left: 0;
	width: 4px;
	height: 4px;
	background: #D9D9D9;
	border-radius: 50%;
}
.dot-left-border {
	position: relative;
	border-left: 1px solid #E7E7E7!important;
}
.dot-left-border:before {
	content: "";
	position: absolute;
	height: 10px;
	width: 10px;
	background-color: #E7E7E7;
	top: -8px;
	left: -5px;
	border-radius: 50%;
}
.dot-left-border:after {
	content: "";
	position: absolute;
	height: 10px;
	width: 10px;
	background-color: #E7E7E7;
	bottom: -8px;
	left: -5px;
	border-radius: 50%;
}
.elm-faculty-list {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 8px;
	list-style: none;
	padding-left: 0px;
